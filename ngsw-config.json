{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/favicon.svg",
          "/index.html",
          "/manifest.webmanifest",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": ["/i18n/**", "/config.json"]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "api-freshness",
      "urls": [
        "https://api.github.com/**",
        "https://gitlab.com/api/**",
        "https://dev.azure.com/**",
        "https://*.atlassian.net/**"
      ],
      "cacheConfig": {
        "maxSize": 50,
        "maxAge": "5m",
        "timeout": "10s",
        "strategy": "freshness"
      }
    }
  ]
}
