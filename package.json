{
  "name": "central-data-manager",
  "version": "2.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "prepare": "husky",
    "format": "prettier --write \"src/**/*.{ts,html,scss}\" \"public/**/*.json\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,scss}\" \"public/**/*.json\"",
    "test:unit": "vitest run"
  },
  "private": true,
  "packageManager": "npm@11.11.0",
  "dependencies": {
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@angular/service-worker": "^22.0.0",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "esbuild": "^0.28.0",
    "marked": "^18.0.5",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.0",
    "@angular/cli": "^22.0.0",
    "@angular/compiler-cli": "^22.0.0",
    "@eslint/js": "^10.0.1",
    "angular-eslint": "^22.0.0",
    "eslint": "^10.4.1",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  },
  "lint-staged": {
    "src/**/*.{ts,html,scss}": [
      "prettier --write"
    ],
    "public/**/*.json": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=22.22.3",
    "npm": ">=10"
  }
}
